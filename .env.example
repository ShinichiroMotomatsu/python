# 楽楽精算の接続情報
RAKURAKU_URL=https://your-company.rakurakuseisan.jp/
RAKURAKU_COMPANY_ID=your_company_id   # マルチテナントの場合のみ必要
RAKURAKU_USER_ID=your_user_id
RAKURAKU_PASSWORD=your_password

# Google Calendar認証ファイルのパス
# Google Cloud Console で OAuth2 クライアントIDを作成し、JSONをダウンロードして配置
GOOGLE_CREDENTIALS_PATH=~/.expense_automation/google_credentials.json
GOOGLE_CALENDAR_ID=primary  # 使用するカレンダーID

# 動作設定
HEADLESS=false      # true にするとブラウザを非表示で実行
DRY_RUN=false       # true にすると申請ボタンを押さない（動作確認用）
SLOW_MO_MS=500      # ブラウザ操作の速度（ミリ秒）。大きくするとゆっくり動作
